  "description": "StraitsX design system — tokens + React components, with Storybook and Chromatic visual regression.",
  "license": "MIT",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./tokens.css": "./src/styles/tokens.css",
    "./global.css": "./src/styles/global.css"
  },
  "files": [
