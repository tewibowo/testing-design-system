# This sandbox lives nested inside the parent `testing-design-system` project,
# which uses a newer Storybook/Vite stack. Without this, `npm install` here
# tries to reconcile the sandbox's Storybook 8 (vite <=6 peer) against the
# parent's vite, producing an ERESOLVE peer conflict. legacy-peer-deps keeps
# this install self-contained: the sandbox gets its own vite 5 + Storybook 8.
legacy-peer-deps=true
